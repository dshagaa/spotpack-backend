# SpotPack Backend — Environment Variables
# Copy these to Supabase secrets (supabase secrets set ...)
# NEVER commit real values to git.

# Bootstrap: first maintainer key (used once to seed api_keys table)
# Generate with: openssl rand -hex 32
SEED_MAINTAINER_KEY=CHANGE_ME

# OpenCode Zen (MiMo V2.5 Free)
OPENCODE_API_KEY=sk-CHANGE_ME
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
VISION_MODEL=mimo-v2.5-free
