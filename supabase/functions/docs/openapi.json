{
  "openapi": "3.1.0",
  "info": {
    "title": "SpotPack Backend API",
    "version": "1.0.0",
    "description": "API para digitalizar schedules de convenciones furry. Subí una imagen → IA extrae los datos → JSON estructurado."
  },
  "servers": [
    { "url": "http://127.0.0.1:54321/functions/v1", "description": "Local Supabase" },
    { "url": "https://{project}.supabase.co/functions/v1", "description": "Production" }
  ],
  "security": [{ "ApiKeyAuth": [] }],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key from api_keys table. Role: general (read/write) or maintainer (full access)."
      }
    },
    "schemas": {
      "Event": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "location": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ScheduleItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "event_id": { "type": "string", "format": "uuid" },
          "day_date": { "type": "string", "format": "date" },
          "start_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
          "end_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "room": { "type": "string" },
          "category": { "type": "string", "enum": ["panel", "meetup", "workshop", "fursuit_games", "dance", "ceremony", "other"] },
          "classification": { "type": "string", "enum": ["general", "+16", "+18", "+21"] },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateEventInput": {
        "type": "object",
        "required": ["name", "start_date", "end_date"],
        "properties": {
          "name": { "type": "string" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "location": { "type": "string" }
        }
      },
      "CreateApiKeyInput": {
        "type": "object",
        "required": ["role", "label"],
        "properties": {
          "role": { "type": "string", "enum": ["general", "maintainer"] },
          "label": { "type": "string" }
        }
      },
      "ApiKeyResponse": {
        "type": "object",
        "properties": {
          "key": { "type": "string", "description": "Raw key — shown once, not stored" },
          "key_hash": { "type": "string" },
          "role": { "type": "string" },
          "label": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/get-events": {
      "get": {
        "summary": "List all events",
        "operationId": "getEvents",
        "tags": ["Events"],
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Events with item counts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "events": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Event" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/get-event": {
      "get": {
        "summary": "Get event with schedule items",
        "operationId": "getEvent",
        "tags": ["Events"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Event with items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "event": { "$ref": "#/components/schemas/Event" },
                    "items": { "type": "array", "items": { "$ref": "#/components/schemas/ScheduleItem" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/create-event": {
      "post": {
        "summary": "Create a new event",
        "operationId": "createEvent",
        "tags": ["Events"],
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateEventInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created event",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "event": { "$ref": "#/components/schemas/Event" } }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/update-event": {
      "patch": {
        "summary": "Update event fields",
        "operationId": "updateEvent",
        "tags": ["Events"],
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "string", "format": "uuid" },
                  "name": { "type": "string" },
                  "start_date": { "type": "string", "format": "date" },
                  "end_date": { "type": "string", "format": "date" },
                  "location": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated event",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "event": { "$ref": "#/components/schemas/Event" } }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/import-schedule": {
      "post": {
        "summary": "Import schedule from image via AI",
        "operationId": "importSchedule",
        "tags": ["Import"],
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["image", "event_id"],
                "properties": {
                  "image": { "type": "string", "format": "binary", "description": "PNG/JPEG/WebP schedule image" },
                  "event_id": { "type": "string", "format": "uuid" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Imported items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "count": { "type": "integer" },
                    "items": { "type": "array", "items": { "$ref": "#/components/schemas/ScheduleItem" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/Unprocessable" },
          "502": { "$ref": "#/components/responses/BadGateway" }
        }
      }
    },
    "/delete-event": {
      "delete": {
        "summary": "Delete event (maintainer only)",
        "operationId": "deleteEvent",
        "tags": ["Events"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "success": { "type": "boolean" } }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/create-api-key": {
      "post": {
        "summary": "Create new API key (maintainer only)",
        "operationId": "createApiKey",
        "tags": ["Admin"],
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateApiKeyInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New API key (raw key shown once)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiKeyResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    }
  },
  "components": {
    "responses": {
      "Unauthorized": { "description": "Missing or invalid API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Forbidden": { "description": "Insufficient role", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "BadRequest": { "description": "Invalid input", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "NotFound": { "description": "Resource not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Unprocessable": { "description": "AI returned unparseable JSON", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "BadGateway": { "description": "AI API error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
    }
  },
  "tags": [
    { "name": "Events", "description": "CRUD for convention events" },
    { "name": "Import", "description": "AI-powered schedule import from images" },
    { "name": "Admin", "description": "API key management (maintainer only)" }
  ]
}
